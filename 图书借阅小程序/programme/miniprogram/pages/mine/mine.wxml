<view class="mine-box" style="padding:30rpx;">
  <view class="record-title" style="font-size:32rpx;font-weight:bold;margin:40rpx 0 20rpx 0;">我的借阅记录</view>
  <view wx:for="{{borrowList}}" wx:key="record_id" class="record-item" style="padding:20rpx;border-bottom:1rpx solid #eee;">
    <text style="font-size:28rpx;display:block;">{{item.book_name}}</text>
    <text wx:if="{{item.status===1}}" style="font-size:24rpx;color:#0066cc;">状态：借阅中</text>
    <text wx:if="{{item.status===2}}" style="font-size:24rpx;color:#09bb07;">状态：已归还</text>
    <!-- 仅借阅中状态展示归还按钮，传递recordId -->
    <button wx:if="{{item.status===1}}" bindtap="backBook" data-recordid="{{item.record_id}}" size="mini" style="margin-top:10rpx;">归还图书</button>
  </view>
  <view wx:if="{{borrowList.length === 0}}" style="text-align:center;color:#999;margin-top:40rpx;">暂无借阅记录</view>
</view>