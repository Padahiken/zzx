<view wx:if="{{book}}" class="detail-box" style="padding:30rpx;">
  <!-- 封面图片代码  -->
  <image class="detail-img" src="{{book.cover_img}}" mode="widthFix" style="width:240rpx;height:320rpx;background:#eee;margin:0 auto;display:block;"></image>

  <view class="info" style="margin-top:30rpx;">
    <text class="title" style="font-size:36rpx;font-weight:bold;display:block;">{{book.book_name}}</text>
    <text class="row" style="font-size:28rpx;color:#555;display:block;margin-top:12rpx;">作者：{{book.author}}</text>
    <text class="row" style="font-size:28rpx;color:#555;display:block;margin-top:12rpx;">ISBN：{{book.isbn}}</text>
    <text class="row" style="font-size:28rpx;color:#555;display:block;margin-top:12rpx;">剩余可借：{{book.total_num - book.borrow_num}} 本</text>
    <text class="desc" style="font-size:26rpx;color:#333;margin-top:20rpx;line-height:1.8;">简介：{{book.desc}}</text>
  </view>
  <button type="primary" bindtap="borrowBtn" style="margin-top:40rpx;">立即借阅</button>
</view>